# Maa Vindhawasini Enterprises Environment Variables Template
# Copy this file to '.env' or add these keys to your hosting platform dashboard.

# Google Tag Manager (GTM) or Google Analytics measurement code (e.g. GTM-XXXXXX or G-XXXXXXXXXX)
VITE_ANALYTICS_ID=your_analytics_gtm_id_here

# Production API Endpoint URL for form submissions (e.g. Netlify/Vercel forms, or CRM API URL)
VITE_FORM_ENDPOINT=https://your-api.endpoint.com/submissions

# Production Cloud File Storage Bucket endpoint (e.g. AWS S3 bucket endpoint for drawing uploads)
VITE_FILE_STORAGE_URL=https://your-s3-bucket-url.com/drawings
